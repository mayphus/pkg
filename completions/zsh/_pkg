#compdef pkg

_pkg_registry_packages() {
  local -a pkgs
  pkgs=(${(f)"$($words[1] list 2>/dev/null | awk 'NR>1 {print $1}')"})
  _describe -t packages 'package' pkgs
}

_pkg_installed_packages() {
  local -a pkgs
  pkgs=(${(f)"$($words[1] installed 2>/dev/null | awk 'NR>2 {print $1}')"})
  _describe -t packages 'installed package' pkgs
}

local -a commands
commands=(
  'help:show general or command help'
  'list:show registry packages'
  'search:search registry packages'
  'installed:show installed packages'
  'show:show package metadata'
  'info:show installed package details'
  'install:install a package'
  'reinstall:reinstall current package version'
  'remove:remove a package'
  'upgrade:upgrade an installed package'
  'plan:print resolved closure and activation changes'
  'why:show which roots require a package'
  'rollback:switch back to the previous profile generation'
  'gc:remove unreachable store objects'
  'self-upgrade:upgrade pkg itself'
  'cleanup:remove build state'
  'audit:report packages missing sha256'
  'version:show pkg source metadata'
  'doctor:print pkg paths'
)

_arguments -C \
  '1:command:->command' \
  '*::arg:->args'

case $state in
  command)
    _describe -t commands 'pkg command' commands
    ;;
  args)
    case "${words[2]}" in
      search)
        _message 'search term'
        ;;
      help)
        if (( CURRENT == 3 )); then
          local -a help_topics
          help_topics=(help list search installed show info install reinstall remove upgrade plan why rollback gc self-upgrade cleanup audit version doctor)
          _describe -t topics 'help topic' help_topics
        fi
        ;;
      show|install|reinstall|plan)
        if [[ "${words[2]}" == "install" && CURRENT == 3 ]]; then
          _values 'install option' --dry-run
        elif [[ "${words[2]}" == "install" && "${words[3]}" == "--dry-run" && CURRENT == 4 ]]; then
          _pkg_registry_packages
        else
          _pkg_registry_packages
        fi
        ;;
      info|remove|why)
        if [[ "${words[2]}" == "remove" && CURRENT == 3 ]]; then
          _values 'remove option' --dry-run
        elif [[ "${words[2]}" == "remove" && "${words[3]}" == "--dry-run" && CURRENT == 4 ]]; then
          _pkg_installed_packages
        else
          _pkg_installed_packages
        fi
        ;;
      upgrade)
        if (( CURRENT == 3 )); then
          local -a upgrade_targets
          upgrade_targets=(--all all --dry-run pkg)
          upgrade_targets+=(${(f)"$($words[1] installed 2>/dev/null | awk 'NR>2 {print $1}')"})
          _describe -t targets 'upgrade target' upgrade_targets
        elif [[ "${words[3]}" == "--dry-run" && CURRENT == 4 ]]; then
          local -a upgrade_targets
          upgrade_targets=(pkg)
          upgrade_targets+=(${(f)"$($words[1] installed 2>/dev/null | awk 'NR>2 {print $1}')"})
          _describe -t targets 'upgrade target' upgrade_targets
        fi
        ;;
      cleanup)
        if (( CURRENT == 3 )); then
          _values 'cleanup option' --cache
        fi
        ;;
    esac
    ;;
esac
