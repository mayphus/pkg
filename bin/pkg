#!/bin/sh
ROOT="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"
JANET_BIN="${HOME}/.local/bin/janet"
JANET_LIB="${HOME}/.local/lib/janet"
export PKG_ROOT="$ROOT"
export JANET_PATH="$JANET_LIB"
cd "$ROOT" || exit 1
if [ -x "$JANET_BIN" ]; then
  exec "$JANET_BIN" "$ROOT/pkg.janet" "$@"
fi
exec janet "$ROOT/pkg.janet" "$@"
